  {
    "id": "a1-basic-word-order",
    "title": "basic sentence order",
    "level": "A1",
    "explanation": "A simple Dutch sentence often follows subject, verb, rest: ik drink water. The verb usually comes second.",
    "examples": [
      {
        "dutch": "Ik drink water.",
        "english": "I drink water."
      },
      {
        "dutch": "Wij gaan naar huis.",
        "english": "We are going home."
      }
    ],
    "linkedTopics": [
