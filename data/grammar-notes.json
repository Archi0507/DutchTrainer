  {
    "id": "b1-word-order-variations",
    "title": "word-order variations",
    "level": "B1",
    "explanation": "Dutch can start with time, place, or another idea for emphasis. The verb still usually comes second: morgen ga ik werken.",
    "examples": [
      {
        "dutch": "Morgen ga ik werken.",
        "english": "Tomorrow I am going to work."
      },
      {
        "dutch": "In de stad koop ik brood.",
        "english": "In the city I buy bread."
      }
