  {
    "id": "a2-modal-verbs",
    "title": "modal verbs",
    "level": "A2",
    "explanation": "Modal verbs like kunnen, moeten, mogen, willen, and zullen help you say what you can, must, may, want, or will do. The main verb often moves to the end.",
    "examples": [
      {
        "dutch": "Ik moet werken.",
        "english": "I have to work."
      },
      {
        "dutch": "Wij kunnen morgen komen.",
        "english": "We can come tomorrow."
      }
    ],
    "linkedTopics": [
      "future plans",
      "work and study",
      "appointments"
    ],
    "linkedLessonGroups": [
      "a2-future-plans",
      "a2-work-study"
    ]
  },
  {
    "id": "a2-past-tense",
    "title": "past tense",
    "level": "A2",
    "explanation": "Dutch often uses hebben or zijn plus a past participle to talk about past events: ik heb gewerkt, ik ben gegaan.",
    "examples": [
      {
        "dutch": "Ik heb gisteren gewerkt.",
        "english": "I worked yesterday."
      },
      {
        "dutch": "Wij zijn naar huis gegaan.",
        "english": "We went home."
      }
    ],
    "linkedTopics": [
      "past events",
      "work and study"
    ],
    "linkedLessonGroups": [
      "a2-past-events",
      "a2-work-study"
    ]
  },
  {
    "id": "a2-adjective-endings",
    "title": "adjective endings",
    "level": "A2",
    "explanation": "Adjectives often get -e before a noun: een grote tafel, de rode auto. Some het-words after een keep the short form.",
    "examples": [
      {
        "dutch": "de rode auto",
        "english": "the red car"
      },
      {
        "dutch": "een klein huis",
        "english": "a small house"
      }
    ],
