  {
    "id": "b1-subordinate-clauses",
    "title": "subordinate clauses",
    "level": "B1",
    "explanation": "After words like omdat, dat, and als, the verb often moves toward the end of the clause.",
    "examples": [
      {
        "dutch": "Ik blijf thuis omdat ik ziek ben.",
        "english": "I am staying home because I am sick."
      },
      {
        "dutch": "Als ik tijd heb, kom ik langs.",
        "english": "If I have time, I will come by."
      }
    ],
