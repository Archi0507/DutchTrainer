  {
    "id": "a1-present-tense-basics",
    "title": "present tense basics",
    "level": "A1",
    "explanation": "In the present tense, ik often uses the short verb form: ik woon, ik drink. With jij, hij, zij, and het, Dutch often adds -t.",
    "examples": [
      {
        "dutch": "Ik woon hier.",
        "english": "I live here."
      },
      {
        "dutch": "Hij werkt vandaag.",
        "english": "He works today."
      }
    ],
    "linkedTopics": [
      "work and study",
      "family and daily routine"
    ],
    "linkedLessonGroups": [
      "a1-family-routine",
      "a2-work-study"
    ]
  },
  {
    "id": "a1-question-words",
    "title": "question words",
    "level": "A1",
    "explanation": "Useful Dutch question words include wie, wat, waar, wanneer, waarom, and hoe. Put the verb right after the question word.",
    "examples": [
      {
        "dutch": "Waar woon je?",
        "english": "Where do you live?"
      },
      {
        "dutch": "Hoe gaat het?",
        "english": "How are you?"
      }
    ],
    "linkedTopics": [
      "greetings and basics",
      "housing and appointments"
    ],
    "linkedLessonGroups": [
      "a0-greetings",
